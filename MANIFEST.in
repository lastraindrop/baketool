# MANIFEST.in - BakeNexus source package layout

include __init__.py
include blender_manifest.toml
include constants.py
include ops.py
include preset_handler.py
include property.py
include state_manager.py
include translations.py
include translations.json
include ui.py
include README.md
include CHANGELOG.md
include LICENSE

recursive-include core *.py
recursive-include docs *.md

prune automation
prune dev_tools
prune test_cases
prune docs/dev
prune docs/legacy

global-exclude __pycache__
global-exclude *.pyc
global-exclude *.pyo
